MoveLargerBar() {
global BarPos, prevBarPos, prevPrevBarPos
global LargerBarPos, prevLargerBarPos, prevPrevLargerBarPos, LargerBarSize
global DisplacementBoost, StopSmoothness ,BounceDetection
global CenteringSpeed, Smoothness, PredictionAdjustment, MovementLimiter, ResponseTiming
if(BounceDetection.Value = 1) {
if(LeftArrowPos < BounceLeftPos.Value && (LeftArrowPos < BarPos && BarPos < RightArrowPos)) {
UpdateCurrentProcess("LeftBounce")
Sleep(BounceLeftHold.Value)
} else if (RightArrowPos > BounceRightPos.Value && (LeftArrowPos < BarPos && BarPos < RightArrowPos)) {
UpdateCurrentProcess("RightBounce")
Click("D")
Sleep(BounceRightHold.Value)
Click("U")
}
}
error := BarPos - LargerBarPos
prevError := prevBarPos - prevLargerBarPos
prevPrevError := prevPrevBarPos - prevPrevLargerBarPos
errorDerivative := error - prevError
errorAcceleration := errorDerivative - (prevError - prevPrevError)
halfLargerBarSize := LargerBarSize / 2
normalizedError := error / halfLargerBarSize
edgeBoost := DisplacementBoost.Value * (Abs(normalizedError) ** 2)
decelerationEffect := StopSmoothness.Value * errorDerivative / (1 + Abs(normalizedError) * 10)
controlSignal := CenteringSpeed.Value * error
+ Smoothness.Value * errorDerivative
+ PredictionAdjustment.Value * errorAcceleration
+ edgeBoost
- decelerationEffect
controlSignal := Max(Min(controlSignal, MovementLimiter.Value), -MovementLimiter.Value)
normalizedControl := controlSignal / MovementLimiter.Value
ratio := (normalizedControl + 1) / 2
ratio := Max(Min(ratio, 1), 0)
maxTime := ResponseTiming.Value * 0.9
minTime := ResponseTiming.Value * 0.1
timeDown := ratio * ResponseTiming.Value
timeUp := ResponseTiming.Value - timeDown
timeDown := Max(Min(timeDown, maxTime), minTime)
timeUp := Max(Min(timeUp, maxTime), minTime)
Click("D")
Sleep(timeDown)
Click("U")
Sleep(timeUp)
}
